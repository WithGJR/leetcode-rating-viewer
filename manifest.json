{
  "manifest_version": 3,
  "name": "LeetCode Rating Viewer",
  "version": "1.0",
  "description": "在 LeetCode 題目頁面顯示題目的 rating",
  "permissions": ["storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://huxulm.github.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
